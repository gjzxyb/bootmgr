# Development defaults for local demos.
# Production must set APP_ENV=production and override ADMIN_PASSWORD,
# JWT_SECRET, CREDENTIAL_KEY, DB_DRIVER, DATABASE_URL, BOOT_BASE_URL,
# CORS_ALLOWED_ORIGINS, IMAGE_STORAGE_DIR, IMAGE_UPLOAD_MAX_MB, and
# ENABLE_DEMO_SEEDER=false with environment-specific values.
APP_ENV=development
HTTP_ADDR=:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081
JWT_SECRET=change-me-in-production
JWT_TTL_HOURS=12
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
TERMINAL_SESSION_TTL_MINUTES=60
DB_DRIVER=postgres
DATABASE_URL=host=postgres user=baremetal password=baremetal dbname=baremetal port=5432 sslmode=disable TimeZone=Asia/Shanghai
DB_CONNECT_MAX_ATTEMPTS=12
DB_CONNECT_RETRY_DELAY_MS=1000
DEPLOYMENT_CONCURRENCY=20
BOOT_SERVICES_ENABLED=false
BOOT_SERVICE_MODE=proxy
BOOT_BIND_INTERFACE=
# Development defaults bind all interfaces; production must use the deployment-network IP, e.g. 192.168.100.10:67.
BOOT_DHCP_LISTEN_ADDR=:67
BOOT_DHCP_SERVER_IP=
BOOT_DHCP_LEASE_START=
BOOT_DHCP_LEASE_END=
# Development defaults bind all interfaces; production must use the deployment-network IP, e.g. 192.168.100.10:69.
BOOT_TFTP_LISTEN_ADDR=:69
BOOT_TFTP_ROOT=data/tftp
BOOT_TFTP_BOOTFILE_UEFI=ipxe.efi
BOOT_TFTP_BOOTFILE_BIOS=undionly.kpxe
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456
CREDENTIAL_KEY=change-this-credential-encryption-key
BMC_ADAPTER=simulated
# Development/lab self-signed Redfish only. Production Redfish endpoints must use https, set false, and trust the BMC CA.
REDFISH_INSECURE_TLS=true
# Optional PEM CA bundle for private BMC Redfish certificates.
REDFISH_CA_CERT_PATH=
COLLECTOR_MODE=simulated
SSH_OPERATIONS_MODE=simulated
# Development default only. Production with COLLECTOR_MODE=ssh or SSH_OPERATIONS_MODE=ssh must use known_hosts.
SSH_HOST_KEY_POLICY=insecure_ignore
SSH_KNOWN_HOSTS_PATH=
SSH_CONNECT_TIMEOUT_SECONDS=10
BOOT_BASE_URL=http://localhost:8080
METADATA_REQUIRE_DEPLOYMENT_NETWORK=false
IMAGE_STORAGE_DIR=data/images
# Real OS ISO uploads usually need a larger value, e.g. 10240 for 10 GB.
IMAGE_UPLOAD_MAX_MB=20
ENABLE_DEMO_SEEDER=true
# Leave VITE_API_BASE_URL/VITE_API_ROOT_URL empty to let the frontend use
# the current browser host with VITE_API_PORT, e.g. http://192.168.1.88:8080.
VITE_API_BASE_URL=
VITE_API_ROOT_URL=
VITE_API_PORT=8080
VITE_IMAGE_UPLOAD_MAX_MB=20
VITE_SHOW_DEMO_CREDENTIALS=true
