FROM node:22-bookworm AS build
WORKDIR /app
ARG VITE_API_BASE_URL=
ARG VITE_API_ROOT_URL=
ARG VITE_API_PORT=8080
ARG VITE_IMAGE_UPLOAD_MAX_MB=20
ARG VITE_SHOW_DEMO_CREDENTIALS=true
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_API_ROOT_URL=$VITE_API_ROOT_URL
ENV VITE_API_PORT=$VITE_API_PORT
ENV VITE_IMAGE_UPLOAD_MAX_MB=$VITE_IMAGE_UPLOAD_MAX_MB
ENV VITE_SHOW_DEMO_CREDENTIALS=$VITE_SHOW_DEMO_CREDENTIALS
COPY package.json package-lock.json* ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
