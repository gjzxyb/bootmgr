# Production example. Copy to .env.production and replace every REPLACE_ME
# before starting a real PXE/BMC/SSH validation environment.
APP_ENV=production
HTTP_ADDR=:8080
CORS_ALLOWED_ORIGINS=https://baremetal.example.com

# These intentionally invalid values keep production startup blocked until changed.
JWT_SECRET=REPLACE_ME
ADMIN_PASSWORD=Admin@123456
CREDENTIAL_KEY=REPLACE_ME

JWT_TTL_HOURS=12
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
TERMINAL_SESSION_TTL_MINUTES=60

POSTGRES_DB=baremetal
POSTGRES_USER=baremetal
POSTGRES_PASSWORD=REPLACE_ME
DB_DRIVER=postgres
DATABASE_URL=host=127.0.0.1 user=baremetal password=REPLACE_ME dbname=baremetal port=5432 sslmode=disable TimeZone=Asia/Shanghai
DB_CONNECT_MAX_ATTEMPTS=30
DB_CONNECT_RETRY_DELAY_MS=1000
DEPLOYMENT_CONCURRENCY=20

# Real PXE/DHCP/TFTP. Use only on an isolated deployment VLAN.
BOOT_SERVICES_ENABLED=true
BOOT_SERVICE_MODE=proxy
BOOT_BIND_INTERFACE=eno2.100
BOOT_DHCP_LISTEN_ADDR=192.168.100.10:67
BOOT_DHCP_SERVER_IP=192.168.100.10
BOOT_DHCP_LEASE_START=
BOOT_DHCP_LEASE_END=
BOOT_TFTP_LISTEN_ADDR=192.168.100.10:69
BOOT_TFTP_ROOT=/app/data/tftp
BOOT_TFTP_BOOTFILE_UEFI=ipxe.efi
BOOT_TFTP_BOOTFILE_BIOS=undionly.kpxe
BOOT_BASE_URL=https://baremetal.example.com
METADATA_REQUIRE_DEPLOYMENT_NETWORK=true

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

ADMIN_EMAIL=admin@example.com
BMC_ADAPTER=redfish
REDFISH_INSECURE_TLS=false
# Optional when BMC Redfish uses a private CA. Put the PEM under deploy/certs
# and set this to /etc/baremetal/certs/redfish-ca.pem.
REDFISH_CA_CERT_PATH=
COLLECTOR_MODE=ssh
SSH_OPERATIONS_MODE=ssh
SSH_HOST_KEY_POLICY=known_hosts
SSH_KNOWN_HOSTS_PATH=/etc/baremetal/known_hosts
SSH_CONNECT_TIMEOUT_SECONDS=10

IMAGE_STORAGE_DIR=/app/data/images
IMAGE_UPLOAD_MAX_MB=20480
ENABLE_DEMO_SEEDER=false

VITE_API_BASE_URL=https://baremetal.example.com/api/v1
VITE_API_ROOT_URL=https://baremetal.example.com
VITE_SHOW_DEMO_CREDENTIALS=false
